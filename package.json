{
	"name": "my-whiteboard",
	"version": "0.1.0",
	"description": "Local-first whiteboard for engineers where coding agents are first-class users",
	"type": "module",
	"private": true,
	"workspaces": [
		"packages/*",
		"apps/*",
		"services/*"
	],
	"scripts": {
		"dev": "npm run dev -w apps/desktop",
		"start": "npm run start -w apps/desktop",
		"build": "npm run build -w apps/desktop",
		"typecheck": "npm run typecheck --workspaces --if-present",
		"test": "npm run test --workspaces --if-present",
		"e2e": "npm run e2e -w apps/desktop",
		"e2e:web": "npm run e2e -w apps/web",
		"e2e:relay": "npm run e2e:relay -w apps/web",
		"build:mac": "npm run build:mac -w apps/desktop",
		"e2e:vscode": "npm run test:integration -w apps/vscode"
	}
}
