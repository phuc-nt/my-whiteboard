{
	"name": "my-whiteboard",
	"productName": "My Whiteboard",
	"version": "0.1.0",
	"description": "Local-first whiteboard for engineers where coding agents are first-class users",
	"main": "./out/main/index.js",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "electron-vite dev",
		"start": "electron-vite preview",
		"build": "npm run typecheck && electron-vite build",
		"typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
		"typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
		"typecheck": "npm run typecheck:node && npm run typecheck:web",
		"test": "vitest run"
	},
	"dependencies": {
		"@electron-toolkit/utils": "^4.0.0",
		"@tldraw/assets": "^5.2.5",
		"mermaid": "^11.16.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tldraw": "5.2.5",
		"yauzl": "^3.4.0",
		"yazl": "^3.3.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@electron-toolkit/tsconfig": "^2.0.0",
		"@types/node": "^25.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@types/yauzl": "^3.4.0",
		"@types/yazl": "^3.3.1",
		"@vitejs/plugin-react": "^5.0.0",
		"electron": "^43.1.1",
		"electron-vite": "^5.0.0",
		"typescript": "^5.9.0",
		"vite": "^7.0.0",
		"vitest": "^4.1.10"
	}
}
