	},
	"peerDependencies": {
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tldraw": "5.2.5"
	},
	"devDependencies": {
		"@types/node": "^25.0.0",
		"@types/react": "^19.0.0",
		"@types/yauzl": "^3.4.0",
		"@types/yazl": "^3.3.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tldraw": "5.2.5",
		"typescript": "^5.9.0",
		"vitest": "^4.1.10"
	}
