{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM"],
		"types": [],
		"strict": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"skipLibCheck": true,
		"isolatedModules": true,
		"jsx": "react-jsx"
	},
	"include": ["src/**/*"]
}
