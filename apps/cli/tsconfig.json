{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022", "DOM"],
		"jsx": "react-jsx",
		"types": ["node"],
		"strict": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"skipLibCheck": true,
		"isolatedModules": true
	},
	"include": ["src/**/*", "vite.config.ts", "vitest.config.ts"]
}
