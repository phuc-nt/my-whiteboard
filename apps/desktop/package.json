{
	"name": "my-whiteboard-desktop",
	"productName": "My Whiteboard",
	"version": "0.1.0",
	"description": "Local-first whiteboard for engineers where coding agents are first-class users",
	"main": "./out/main/index.js",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "electron-vite dev",
		"start": "electron-vite preview",
		"build": "npm run typecheck && electron-vite build",
		"typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
		"typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
		"typecheck": "npm run typecheck:node && npm run typecheck:web",
		"test": "vitest run",
		"e2e": "electron-vite build && playwright test",
		"build:mac": "electron-vite build && electron-builder --mac",
		"build:linux": "electron-vite build && electron-builder --linux"
	},
	"dependencies": {
		"@electron-toolkit/utils": "^4.0.0",
		"@mywb/core": "*",
		"@mywb/node-adapter": "*",
		"@tldraw/assets": "^5.2.5",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tldraw": "5.2.5",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@electron-toolkit/tsconfig": "^2.0.0",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"@playwright/test": "^1.61.1",
		"@types/node": "^25.0.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^5.0.0",
		"electron": "^43.1.1",
		"electron-builder": "^26.15.3",
		"electron-vite": "^5.0.0",
		"typescript": "^5.9.0",
		"vite": "^7.0.0",
		"vitest": "^4.1.10"
	},
	"homepage": "https://github.com/phuc-nt/my-whiteboard",
	"author": {
		"name": "phuc-nt",
		"email": "phucnt0@gmail.com"
	}
}
